# === NanoClaw / LifeOS ===

# Assistant name (displayed in Discord, used as trigger)
ASSISTANT_NAME=LifeOS

# Anthropic API key
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Discord bot token
# Create bot at: https://discord.com/developers/applications
# Enable MESSAGE_CONTENT intent
DISCORD_BOT_TOKEN=

# GitHub
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=

# Google / Gmail
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Run the one-time auth: npx @gongrzhe/server-gmail-autoauth-mcp auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# MotherDuck
# Get at: https://app.motherduck.com/account/settings
MOTHERDUCK_TOKEN=

# Timezone (IANA format)
TZ=America/Edmonton
