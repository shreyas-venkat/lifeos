# GitHub
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=

# Google / Gmail
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Run the one-time auth to get a refresh token, then store the values below.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# MotherDuck
# Get at: https://app.motherduck.com/account/settings
MOTHERDUCK_TOKEN=

# VPS (coming soon)
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY_PATH=
