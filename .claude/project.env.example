# .claude/project.env
# Project-specific Claude Code hook configuration.
# Copy this to .claude/project.env and fill in values.
# This file is gitignored — never commit it.

# Test command to run after every file edit and at Stop.
# Examples:
#   TEST_CMD="python -m pytest tests/ -v"
#   TEST_CMD="npm test"
#   TEST_CMD="go test ./... -v"
#   TEST_CMD="cargo test"
#   TEST_CMD="dbt test"
TEST_CMD=""

# Template repo remote URL (default: shreyas-venkat/claude-templates via SSH).
# Change to HTTPS if SSH is not set up:
#   TEMPLATE_REPO="https://github.com/shreyas-venkat/claude-templates.git"
TEMPLATE_REPO="git@github.com:shreyas-venkat/claude-templates.git"

# Set to "true" to skip template sync on push.
# Should be "true" in claude-templates itself to avoid self-referential sync.
SKIP_TEMPLATE_SYNC="false"
